This is the "signature decorative container" — use it for quotes, pinned thoughts, or any highlighted block.

6.8 Photo slot
Gold-framed image container with aspect-ratio variants.

.photo-slot {
  position: relative;
  width: 100%;
  background: #141413;
  border: 1px solid rgba(201,169,110,0.25);
  overflow: hidden;
  transition: border-color 0.3s ease, transform 0.3s ease;
}
.photo-slot::before {
  content: '';
  position: absolute;
  inset: 0;
  box-shadow: inset 0 0 0 1px rgba(255,220,150,0.06);
  pointer-events: none;
}
.photo-slot:hover {
  border-color: rgba(201,169,110,0.5);
  transform: translateY(-2px);
}
.photo-slot img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}

/* Aspect ratio modifiers */
.photo-slot.ratio-16-9 { aspect-ratio: 16 / 9; }
.photo-slot.ratio-4-3  { aspect-ratio: 4 / 3;  }
.photo-slot.ratio-3-4  { aspect-ratio: 3 / 4;  }
.photo-slot.ratio-1-1  { aspect-ratio: 1 / 1;  }

/* 3-column grid that collapses */
.photo-grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}
@media (max-width: 720px) {
  .photo-grid-3 { grid-template-columns: 1fr; }
}

Captions below photos use font-mono text-[9px] uppercase tracking-[0.2em] text-text-dim mt-2.

6.9 Circular portrait frame (hero)
.portrait-frame {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 50%;
  overflow: hidden;
  isolation: isolate;
}
.portrait-frame img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: 50% 0%;   /* anchor top of tall portraits */
}
.portrait-frame-ring {
  position: absolute; inset: 0;
  border-radius: 50%;
  border: 1.5px solid rgba(201,169,110,0.55);
  box-shadow:
    inset 0 0 0 1px rgba(255,220,150,0.15),
    0 0 30px rgba(201,169,110,0.18),
    0 0 60px rgba(201,169,110,0.10);
}
.portrait-frame-glow {
  position: absolute; inset: -22%;
  border-radius: 50%;
  background: radial-gradient(circle at center,
    rgba(255,230,170,0.28) 0%,
    rgba(201,169,110,0.16) 28%,
    rgba(201,169,110,0.06) 50%,
    transparent 72%);
  filter: blur(20px);
  animation: haloBreath 6s ease-in-out infinite alternate;
}
@keyframes haloBreath {
  0%   { opacity: 0.85; transform: scale(1);    }
  100% { opacity: 1;    transform: scale(1.06); }
}

HTML:

<div class="portrait-frame">
  <div class="portrait-frame-glow"></div>
  <div class="portrait-frame-ring"></div>
  <img src="portrait.jpg" alt="" />
</div>

